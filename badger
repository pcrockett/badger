#!/usr/bin/env nu

let XDG_STATE_HOME = ($env.XDG_STATE_HOME? | default $"($env.HOME)/.local/state")
let BADGER_STATE_DIR = $"($XDG_STATE_HOME)/badger"

def main [] {
  mkdir $BADGER_STATE_DIR
}

def "main publish" [
  message: string
  --level(-l) = "info"
  --verbose(-v)
] {
  let file_path = (
    {
      message: $message
      level: $level
    }
    | save-notification
  )

  if $verbose {
    $"Saved to ($file_path)" | print
  }
}

def "main next" [] {
  let next_file = try {
    ls $BADGER_STATE_DIR | first
  } catch {|err|
    let err_metadata = $err.json? | default "{}" | from json
    if ($err_metadata.code? == "nu::shell::io::not_found") {
      null
    } else {
      error make $err
    }
  }
  if ($next_file | is-empty) {
    return
  }

  let message = $next_file.name | open | get message
  rm $next_file.name
  $message | print
}

def save-notification []: record -> string {
  let payload = $in
  mkdir $BADGER_STATE_DIR
  let now = date now | date to-timezone UTC

  mut index = 0
  mut file_path = ""
  while true {
    let slug = get-slug $now $index
    $file_path = $"($BADGER_STATE_DIR)/($slug).json"

    let save_success = try {
      $payload | save $file_path
      true
    } catch {|err|
      if ($err.msg == "Destination file already exists") {
        false  # nonfatal error; increment index and try again
      } else {
        error make $err  # fatal error; we don't know what happened, abort
      }
    }

    if $save_success {
      break
    }

    if ($index >= 999) {
      error make {
        msg: "Exhausted unique message slugs"
      }
    }

    $index = $index + 1
  }

  $file_path
}

def get-slug [time: datetime index: number]: nothing -> string {
  let timestamp = $env.BADGER_TIMESTAMP? | default { ($time | format date "%+") }
  let padded_index = $index | fill --character '0' --width 3 --alignment right
  $"($timestamp)_($padded_index)"
}

def not-implemented [] {
  error make { msg: "not implemented yet" }
}
