#!/usr/bin/env -S nu --stdin

let XDG_STATE_HOME = ($env.XDG_STATE_HOME? | default $"($env.HOME)/.local/state")
let BADGER_STATE_DIR = $"($XDG_STATE_HOME)/badger"

# Publish and view notifications in your terminal
def main [] {
  const SELF = path self
  ^$SELF --help
}

# Publish a notification
def "main publish" [
  message: string
  --level(-l) = "info"
  --verbose(-v)
  --data(-d): string     # JSON data to attach (`-` to read stdin)
] {
  let data = if ($data == "-") {
    $in
  } else {
    $data
  }

  let file_path = (
    {
      message: $message
      level: $level
    }
    | insert-if data { $data | is-not-empty } { $data | from json }
    | save-notification
  )

  if $verbose {
    $"Saved to ($file_path)" | print
  }
}

# Display the next notification in the list
def "main next" [
  --peek(-p)          # Don't take it out of the queue
  --format = "quiet"  # quiet, json, or verbose
] {
  let next_file = next-notification-file
  if ($next_file | is-empty) {
    return
  }

  let payload = $next_file | open | upsert file $next_file
  let result = match ($format) {
    quiet   => { $payload.message }
    verbose => { ($payload | table --expand) }
    json    => { ($payload | to json) }
    _       => {
      error make {
        msg: $"Unrecognized format: `($format)` -- can only be one of quiet, verbose, json"
      }
    }
  }

  if not $peek {
    rm $next_file
  }
  $result | print
}

# Get notification count
def "main count" [] {
  list-notification-files | length | print
}

# Determine by exit code if notifications are pending
def "main pending" [] {
  if (list-notification-files | is-empty) {
    exit 1  # don't display anything in the prompt
  }
}

def save-notification []: record -> string {
  let payload = $in
  mkdir $BADGER_STATE_DIR
  let now = date now | date to-timezone UTC

  mut index = 0
  mut file_path = ""
  while true {
    let slug = get-slug $now $index
    $file_path = $"($BADGER_STATE_DIR)/($slug).json"

    let save_success = try {
      $payload | save $file_path
      true
    } catch {|err|
      if ($err.msg == "Destination file already exists") {
        false  # nonfatal error; increment index and try again
      } else {
        error make $err  # fatal error; we don't know what happened, abort
      }
    }

    if $save_success {
      break
    }

    if ($index >= 999) {
      error make {
        msg: "Exhausted unique message slugs"
      }
    }

    $index = $index + 1
  }

  $file_path
}

def next-notification-file []: nothing -> string {
  list-notification-files | first
}

def list-notification-files []: nothing -> list<string> {
  try {
    ls $BADGER_STATE_DIR | each { $in.name }
  } catch {|err|
    let err_metadata = $err.json? | default "{}" | from json
    if ($err_metadata.code? == "nu::shell::io::not_found") {
      []
    } else {
      error make $err
    }
  }
}

def get-slug [time: datetime index: number]: nothing -> string {
  let timestamp = $env.BADGER_TIMESTAMP? | default { ($time | format date "%+") }
  let padded_index = $index | fill --character '0' --width 3 --alignment right
  $"($timestamp)_($padded_index)"
}

def insert-if [field: string, condition: closure, value: closure]: record -> record {
  let item = $in
  if ($item | do $condition) {
    $item | insert $field ($item | do $value)
  } else {
    $item
  }
}

def not-implemented [] {
  error make { msg: "not implemented yet" }
}
