#!/usr/bin/env nu

let XDG_STATE_HOME = ($env.XDG_STATE_HOME? | default $"($env.HOME)/.local/state")
let BADGER_STATE_DIR = $"($XDG_STATE_HOME)/badger"

# Publish and view notifications in your terminal
def main [] {
  const SELF = path self
  ^$SELF --help
}

# Publish a notification
def "main publish" [
  message: string
  --level(-l) = "info"
  --verbose(-v)
] {
  let file_path = (
    {
      message: $message
      level: $level
    }
    | save-notification
  )

  if $verbose {
    $"Saved to ($file_path)" | print
  }
}

# Display the next notification in the list
def "main next" [
  --peek(-p)    # don't take it out of the queue
  --verbose(-v)
] {
  let next_file = next-notification-file
  if ($next_file | is-empty) {
    return
  }

  let payload = $next_file | open
  let result = if $verbose {
    $payload | upsert file $next_file | table
  } else {
    $payload.message
  }

  if not $peek {
    rm $next_file
  }
  $result | print
}

# Get notification count
def "main count" [] {
  list-notification-files | length | print
}

# Determine by exit code if notifications are pending
def "main pending" [] {
  if (list-notification-files | is-empty) {
    exit 1  # don't display anything in the prompt
  }
}

# WIP: Run a command and publish a notification if it exits non-zero
def "main run" [...args] {

  # unfortunately nushell script parameter parsing is a bit of a mess. there are
  # different ways you can do it, but they all have their quirks. for example:
  #
  # - the [...args] method makes it impossible to pass anything that starts with a
  #   hyphen, i.e. `badger run nu -c ...` because it'll be interpreted as a parameter
  #   for THIS function.
  # - if we use [args: string] then we couldn't run the "false" command because it gets
  #   recognized as a bool rather than treated as a string, generating a parse error.
  # - if we use [args: list<string>] then we have to specify weird brackets around it
  #
  # etc. i think until nushell gets production-ready, we'll have to accept that we need
  # a different language to represent what we're trying to do here.

  let result = ^$args | tee { print } | complete
  if $result.exit_code == 0 {
    exit
  }

  (
    main publish
    $"Command `($args | str join ' ')` exited with code ($result.exit_code)"
    --level error

    # TODO: add $result to notification metadata
  )

  exit $result.exit_code
}

def save-notification []: record -> string {
  let payload = $in
  mkdir $BADGER_STATE_DIR
  let now = date now | date to-timezone UTC

  mut index = 0
  mut file_path = ""
  while true {
    let slug = get-slug $now $index
    $file_path = $"($BADGER_STATE_DIR)/($slug).json"

    let save_success = try {
      $payload | save $file_path
      true
    } catch {|err|
      if ($err.msg == "Destination file already exists") {
        false  # nonfatal error; increment index and try again
      } else {
        error make $err  # fatal error; we don't know what happened, abort
      }
    }

    if $save_success {
      break
    }

    if ($index >= 999) {
      error make {
        msg: "Exhausted unique message slugs"
      }
    }

    $index = $index + 1
  }

  $file_path
}

def next-notification-file []: nothing -> string {
  list-notification-files | first
}

def list-notification-files []: nothing -> list<string> {
  try {
    ls $BADGER_STATE_DIR | each { $in.name }
  } catch {|err|
    let err_metadata = $err.json? | default "{}" | from json
    if ($err_metadata.code? == "nu::shell::io::not_found") {
      []
    } else {
      error make $err
    }
  }
}

def get-slug [time: datetime index: number]: nothing -> string {
  let timestamp = $env.BADGER_TIMESTAMP? | default { ($time | format date "%+") }
  let padded_index = $index | fill --character '0' --width 3 --alignment right
  $"($timestamp)_($padded_index)"
}

def not-implemented [] {
  error make { msg: "not implemented yet" }
}
